    "preview": "vite preview --host 127.0.0.1",
    "check:cloudflare": "node scripts/check_cloudflare_dist.mjs",
    "preview:prod": "npm run build && npm run preview",
    "audit:dist": "node scripts/audit_dist_v10.mjs",
    "data:minify": "node scripts/minify_public_data_v10.mjs",
    "check:client-counts": "node scripts/check_v10_client_counts.mjs",
    "check:data-contracts": "node scripts/check_data_contracts.mjs",
    "check:business-contracts": "node scripts/check_business_contracts.mjs",
    "check:geo-contracts": "node scripts/check_geo_contracts.mjs",
    "check:map-smoke": "node scripts/check_map_smoke_v10_3.mjs",
    "validate:release": "npm run build && npm run check:data-contracts && npm run check:business-contracts && npm run check:geo-contracts",
    "audit:architecture": "node scripts/audit_architecture_v10_4.mjs",
    "audit:data-loading": "node scripts/audit_data_loading_v10_4.mjs",
    "audit:dependencies": "node scripts/audit_dependencies_v10_4.mjs",
    "validate:architecture": "npm run audit:architecture && npm run audit:data-loading && npm run audit:dependencies",
    "validate:v10.4": "npm run validate:release && npm run validate:architecture",
